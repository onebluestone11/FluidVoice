<Window x:Class="FluidVoice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FluidVoice Windows MVP"
        Height="420"
        Width="720"
        MinHeight="360"
        MinWidth="560">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="FluidVoice Windows MVP"
                       FontSize="24"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding StatusText}"
                       Margin="0,6,0,0"
                       Foreground="#555555" />
        </StackPanel>

        <TextBox Grid.Row="1"
                 Text="{Binding TranscriptText, Mode=OneWay}"
                 AcceptsReturn="True"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontSize="16"
                 Padding="12" />

        <StackPanel Grid.Row="2"
                    Margin="0,16,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Start Dictation"
                    Command="{Binding StartDictationCommand}"
                    MinWidth="130"
                    Padding="12,8" />
            <Button Content="Stop Dictation"
                    Command="{Binding StopDictationCommand}"
                    MinWidth="130"
                    Margin="12,0,0,0"
                    Padding="12,8" />
        </StackPanel>
    </Grid>
</Window>
